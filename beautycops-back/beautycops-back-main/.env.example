# Local development uses PostgreSQL only (Docker on port 5433 to avoid conflict with local PostgreSQL on 5432).
# Copy to .env and adjust. manage.py loads .env automatically.
# Option A – single URL:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE

# Option B – separate vars (matches docker-compose-local.yml; host port 5433):
# POSTGRES_DB=Beauty-cobs
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=admin123
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5433

# Frontend (Next.js) – point to backend API (no trailing slash)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
